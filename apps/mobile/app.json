{
  "expo": {
    "name": "Simple Syncing Audiobook",
    "slug": "simple-syncing-audiobook",
    "version": "0.2.1",
    "orientation": "portrait",
    "scheme": "simple-syncing-audiobook",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f97316"
      },
      "package": "com.simplesyncing.audiobook"
    },
    "plugins": [
      "expo-router",
      "expo-document-picker"
    ],
    "ios": {
      "bundleIdentifier": "com.simplesyncing.audiobook"
    }
  }
}
